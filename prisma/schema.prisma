// Prisma schema cho website affiliate + CMS
// DB: MySQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Tài khoản quản trị CMS
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String // mật khẩu đã hash bằng bcrypt
  name      String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  EDITOR
}

// Danh mục sản phẩm
model Category {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

// Sản phẩm affiliate
model Product {
  id            Int       @id @default(autoincrement())
  name          String
  slug          String    @unique
  description   String?   @db.Text // mô tả ngắn
  content       String?   @db.LongText // mô tả chi tiết (HTML)
  price         Int       @default(0) // giá gốc (VND)
  salePrice     Int? // giá khuyến mãi (VND), null nếu không có
  imageUrl      String? // ảnh đại diện
  gallery       String?   @db.Text // JSON mảng URL ảnh phụ
  affiliateUrl  String    @db.Text // link affiliate "Mua ngay" (mặc định / dự phòng)
  store         String? // tên sàn chính: Shopee, Lazada, Tiki...
  rating        Float?    @default(0) // điểm đánh giá 0-5
  // ===== Review kiểu Wirecutter =====
  pros          String?   @db.Text // ưu điểm, mỗi dòng 1 ý
  cons          String?   @db.Text // nhược điểm, mỗi dòng 1 ý
  bestFor       String?   @db.Text // "Ai nên mua" / phù hợp với ai
  compareIds    String?   @db.Text // JSON mảng id sản phẩm để so sánh; trống = tự động theo danh mục
  featured      Boolean   @default(false) // sản phẩm nổi bật
  published     Boolean   @default(true)
  clicks        Int       @default(0) // số lượt bấm mua (theo dõi hiệu quả)
  categoryId    Int?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clickEvents   ClickEvent[]
  offers        Offer[] // nhiều link mua ở nhiều sàn để so giá

  @@index([categoryId])
  @@index([featured])
  @@index([published])
}

// Link mua ở từng sàn (Shopee/Lazada/Tiki...) cho 1 sản phẩm, kèm giá để so sánh.
model Offer {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     String  // tên sàn: Shopee, Lazada, Tiki...
  url       String  @db.Text // link affiliate tới sàn đó
  image     String? @db.Text // ảnh riêng của sàn này (trống = dùng ảnh sản phẩm)
  price     Int? // giá tại sàn này (VND), null nếu không nhập
  clicks    Int     @default(0) // lượt bấm riêng cho link sàn này
  position  Int     @default(0) // thứ tự hiển thị

  @@index([productId])
}

// Ghi lại từng lượt bấm "Mua ngay" để vẽ biểu đồ theo ngày / danh mục / sản phẩm.
// categoryId được lưu kèm (denormalize) để thống kê theo danh mục nhanh, không
// bị ảnh hưởng nếu sau này sản phẩm đổi danh mục.
model ClickEvent {
  id         Int      @id @default(autoincrement())
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId Int?
  createdAt  DateTime @default(now())

  @@index([productId])
  @@index([categoryId])
  @@index([createdAt])
}

// Bài viết / Tin tức
model Post {
  id              Int       @id @default(autoincrement())
  title           String
  slug            String    @unique
  excerpt         String?   @db.Text // tóm tắt
  content         String    @db.LongText // nội dung HTML
  coverImage      String?
  // ===== SEO =====
  metaTitle       String?   // thẻ <title> tùy chỉnh (để trống dùng tiêu đề)
  metaDescription String?   @db.Text // meta description (để trống dùng tóm tắt)
  focusKeyword    String?   // từ khóa chính để đối chiếu SEO
  ogImage         String?   // ảnh đại diện khi chia sẻ lên mạng xã hội
  published       Boolean   @default(true)
  publishedAt     DateTime?
  views           Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([published])
}

// Cấu hình site dạng key-value (tên site, logo, nội dung trang giới thiệu, liên hệ...)
model Setting {
  key   String @id
  value String @db.LongText
}
