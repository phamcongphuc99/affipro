# ====== Cấu hình kết nối MySQL ======
# Sửa user, password, host, port và tên database cho đúng máy của bạn.
# Ví dụ: mysql://root:matkhau@localhost:3306/affiliate_db
DATABASE_URL="mysql://root:password@localhost:3306/affiliate_db"

# ====== Bảo mật phiên đăng nhập admin (JWT) ======
# Chuỗi bí mật ngẫu nhiên, dài (>= 32 ký tự). Tạo bằng: openssl rand -base64 32
AUTH_SECRET="thay-bang-chuoi-bi-mat-ngau-nhien-dai-toi-thieu-32-ky-tu"

# ====== Tài khoản admin khởi tạo (dùng cho lệnh seed) ======
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123456"
ADMIN_NAME="Quản trị viên"

# URL gốc của site (dùng cho metadata, SEO)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
